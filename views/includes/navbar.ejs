<style>
  .navbar{
    z-index: 1080;
  }
  .search-btn{
    background-color: #fe424d;
    color: #fff;
    display: flex;
    align-items: center;
    border-radius: 3rem;
    
  }
  .search-btn i{
    margin-right: 0.5rem;
  }
  .search-btn:hover{
    background-color: #fe424d;
    color: #fff;
  }
  .search-inp{
    border-radius: 3rem;
  }
  .navbar-collapse{
    background-color: #fff;
  }

  @media (max-width: 767.98px){
    .navbar-collapse{
      position: relative;
      z-index: 1090;
      padding: 0.75rem 0 1rem;
      border-top: 1px solid #ececec;
      box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.08);
    }

    .navbar-nav{
      gap: 0.35rem;
    }

    .navbar-nav.ms-auto{
      margin-left: 0 !important;
      margin-top: 0.75rem;
    }

    .navbar-nav .nav-link{
      padding-left: 0;
      padding-right: 0;
    }

    .navbar form[role="search"]{
      display: flex;
      flex-wrap: nowrap;
      width: 100%;
    }

    .search-inp{
      min-width: 0;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-body-tertiary sticky-top border-bottom">
    <div class="container-fluid">
      <a class="navbar-brand" href="/listings"><i class="fa-solid fa-compass"></i></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link active" href="/listings"><b>Explore</b></a>
        </div>
        <div class="navbar-nav ms-auto">
          <form class="d-flex" role="search" method="GET" action="/listings">
            <input
              name="q"
              class="form-control me-2 search-inp"
              type="search"
              placeholder="Search your destination"
              aria-label="Search"
              value="<%= typeof listingFilters !== 'undefined' ? listingFilters.q : '' %>"
            >
            <button class="btn search-btn" type="submit"><i class="fa-solid fa-search"></i>Search</button>
          </form>
        </div>
        <div class="navbar-nav ms-auto">
        <%  if(!currUser){ %>
            <a class="nav-link active" href="/signup"><b>SignUp</b></a>
            <a class="nav-link active" href="/login"><b>Login</b></a>
        <% } %>
        <%  if(currUser){ %>  
          <% if(currUser.role === "host" || currUser.role === "admin"){ %>
            <a class="nav-link active" href="/listings/new">WanderLust your home</a>
            <a class="nav-link active" href="/bookings/host"><b>Host Booking Requests</b></a>
            <a class="nav-link active" href="/bookings/host/dashboard"><b>Host Analytics</b></a>
          <% } %>
          <% if(currUser.role === "user" || currUser.role === "admin"){ %>
            <a class="nav-link active" href="/bookings/me"><b>My Bookings</b></a>
          <% } %>
          <% if(currUser.role === "user" && currUser.hostRequestStatus !== "pending"){ %>
            <a class="nav-link active" href="/become-host"><b>Become a Host</b></a>
          <% } %>
          <% if(currUser.role === "user" && currUser.hostRequestStatus === "pending"){ %>
            <span class="nav-link text-warning"><b>Host Request Pending</b></span>
          <% } %>
          <% if(currUser.role === "admin"){ %>
            <a class="nav-link active" href="/admin"><b>Admin Panel</b></a>
          <% } %>
          <a class="nav-link active" href="/logout">Logout</a>
        <% } %>  
        </div>
      </div>
    </div>
</nav>
