<%- layout("./layouts/boilerplate.ejs") -%>
<script>
  const mapToken = "<%=process.env.MAP_TOKEN%>";
  const listing = <%- JSON.stringify(listing) %>;
</script>
<div class="row">
  <div class="col-8 offset-2">
    <h3><%= listing.title %></h3>

    <div class="card col listing-card">
      <img src="<%= (listing.image && listing.image.url) ? listing.image.url : 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1200&auto=format&fit=crop' %>" class="card-img-top" style="height: 20rem;" alt="Listing_image">
      <div class="card-body">
        <p class="card-text mt-3"><i>OwnedBy_<%= listing.owner ? listing.owner.username : "Unknown host" %></i></p>
        <p class="card-text mt-3"><b>About:- </b><%= listing.description %></p>
        <p class="card-text"><b>Price:- </b> &#8377;<%= listing.price.toLocaleString("en-IN") %></p>
        <p class="card-text"><b>Address:- </b><%= listing.location %></p>
        <p class="card-text"><b>Country:- </b><%= listing.country %></p>
      </div>
    </div>
<!-- Edit and delete buttons only visible to owner/admin -->
    <% if(currUser && listing.owner && (currUser._id.equals(listing.owner._id) || currUser.role === "admin")){ %>
    <div class="show-btns">
      <a href="/listings/<%= listing._id %>/edit" class="btn show-btn-edit">Edit</a>
      <br> <br>
      <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark show-btn-dlt">Delete</button>
      </form>
    </div>
    <% } %>
   

    <hr>

    <div class="col mb-4">
      <h3>Book this stay</h3>
      <% if(currUser && currUser.role !== "host"){ %>
      <form id="bookingForm" action="/listings/<%= listing._id %>/bookings" method="POST" class="row g-3 needs-validation" novalidate>
        <div class="col-md-4">
          <label for="checkIn" class="form-label">Check-in</label>
          <input type="date" id="checkIn" name="booking[checkIn]" class="form-control" required>
          <div class="invalid-feedback">Please select check-in date.</div>
        </div>
        <div class="col-md-4">
          <label for="checkOut" class="form-label">Check-out</label>
          <input type="date" id="checkOut" name="booking[checkOut]" class="form-control" required>
          <div class="invalid-feedback">Please select check-out date.</div>
        </div>
        <div class="col-md-4">
          <label for="guests" class="form-label">Guests</label>
          <input type="number" id="guests" name="booking[guests]" class="form-control" min="1" max="20" value="1" required>
          <div class="invalid-feedback">Please enter guest count.</div>
        </div>
        <div class="col-12">
          <p id="availabilityMsg" class="text-danger mb-2" style="display:none;"></p>
          <button class="btn btn-dark">Book Now</button>
        </div>
      </form>
      <% } else if(currUser && currUser.role === "host"){ %>
        <div class="alert alert-warning mb-0">
          Hosts cannot book listings. Switch to a normal user account if you want to make bookings.
        </div>
      <% } else { %>
        <p class="mb-2">Login to book this listing.</p>
        <a href="/login" class="btn btn-outline-dark">Login to Book</a>
      <% } %>
    </div>

    <hr>

    <div class="col">
    <h3>Leave a Review</h3>
    <form action="/listings/<%= listing.id %>/reviews" method="post" class="needs-validation" novalidate>
      <div class="mt-3">
        <fieldset class="starability-slot">
          <legend>Rating:</legend>
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
          <input type="radio" id="first-rate1" name="review[rating]" value="1" />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input type="radio" id="first-rate2" name="review[rating]" value="2" />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input type="radio" id="first-rate3" name="review[rating]" value="3" />
          <label for="first-rate3" title="Average">3 stars</label>
          <input type="radio" id="first-rate4" name="review[rating]" value="4" />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input type="radio" id="first-rate5" name="review[rating]" value="5" />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
      </div>
      <div class="mt-3 mb-3">
        <label for="comment" class="form-label">Comment</label>
        <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please provide a valid Comment.</div>
      </div>
      <button class="btn btn-outline-dark mb-3">Submit</button>
    </form>
    </div>

    <hr>
    
    <% if(listing.reviews.length > 0){ %>
    <div class="col mb-3">
      <div class="row">
        <h4>Recent Reviews</h4>
        <% for(review of listing.reviews) {%>
          <div class="card col-5 ms-3 mb-3">
            <div class="card-body">
              <h5 class="card-title"><i><b>@<%= review.author.username %></b></i></h5>
              <h6 class="card-subtitle mb-2 text-body-secondary"><%= review.comment %></h6>
              <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
            </div>

            <form method="post" action="/listings/<%=listing.id%>/reviews/<%=review.id%>?_method=DELETE">
              <button class="btn btn-sm btn-dark mb-3 mt-2">Delete</button>
            </form>

          </div>
        <% } %>
      </div>
    </div>
    <% } %>

    <div class="col mb-3">
      <h4>Where you'll be</h4>
      <div id="map"></div>

      <script src="/js/map.js"></script> 
      <script>
        const today = new Date().toISOString().split("T")[0];
        const checkInInput = document.getElementById("checkIn");
        const checkOutInput = document.getElementById("checkOut");
        const bookingForm = document.getElementById("bookingForm");
        const availabilityMsg = document.getElementById("availabilityMsg");

        if (checkInInput && checkOutInput) {
          checkInInput.min = today;
          checkOutInput.min = today;

          checkInInput.addEventListener("change", () => {
            checkOutInput.min = checkInInput.value || today;
          });
        }

        if (bookingForm && checkInInput && checkOutInput && availabilityMsg) {
          let isSubmitting = false;

          bookingForm.addEventListener("submit", async (event) => {
            if (isSubmitting) return;

            const checkIn = checkInInput.value;
            const checkOut = checkOutInput.value;
            if (!checkIn || !checkOut) return;

            event.preventDefault();
            availabilityMsg.style.display = "none";
            availabilityMsg.innerText = "";

            try {
              const query = new URLSearchParams({ checkIn, checkOut });
              const response = await fetch(`/listings/<%= listing._id %>/bookings/availability?${query.toString()}`);
              const data = await response.json();

              if (!response.ok || !data.available) {
                availabilityMsg.innerText = data.message || "Selected dates are not available.";
                availabilityMsg.style.display = "block";
                return;
              }

              isSubmitting = true;
              bookingForm.submit();
            } catch (err) {
              availabilityMsg.innerText = "Could not verify availability. Please try again.";
              availabilityMsg.style.display = "block";
            }
          });
        }
      </script>
    </div>
    
  </div>
</div>
