<% layout("./layouts/boilerplate.ejs") -%>

<div class="row mt-3">
  <div class="col-10 offset-1">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h3 class="mb-1">Admin Listings</h3>
        <p class="text-muted mb-0">Review listing inventory, check activity, and remove listings when needed.</p>
      </div>
      <div class="d-flex gap-2">
        <a href="/admin/bookings" class="btn btn-outline-secondary">Manage Bookings</a>
        <a href="/admin" class="btn btn-outline-dark">Back to Admin Panel</a>
      </div>
    </div>

    <% if (listingsWithStats.length === 0) { %>
      <div class="alert alert-info">There are no listings to manage right now.</div>
    <% } else { %>
      <div class="row">
        <% for (const item of listingsWithStats) { %>
          <% const listing = item.listing; %>
          <% const stats = item.stats; %>
          <div class="col-lg-6 mb-4">
            <div class="card h-100">
              <img
                src="<%= (listing.image && listing.image.url) ? listing.image.url : 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1200&auto=format&fit=crop' %>"
                class="card-img-top"
                alt="admin_listing_image"
                style="height: 15rem;"
              >
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3">
                  <div>
                    <h5 class="card-title mb-1"><%= listing.title %></h5>
                    <p class="card-text text-muted mb-2">
                      <%= listing.location %>, <%= listing.country %>
                    </p>
                  </div>
                  <span class="badge text-bg-dark">INR <%= Number(listing.price || 0).toLocaleString("en-IN") %></span>
                </div>

                <p class="card-text mb-1">
                  <b>Owner:</b> <%= listing.owner ? listing.owner.username : "Deleted user" %>
                </p>
                <p class="card-text mb-1">
                  <b>Email:</b> <%= listing.owner ? listing.owner.email : "N/A" %>
                </p>
                <p class="card-text mb-1">
                  <b>Reviews:</b> <%= listing.reviews ? listing.reviews.length : 0 %>
                </p>
                <p class="card-text mb-1">
                  <b>Total Bookings:</b> <%= stats.totalBookings %>
                </p>
                <p class="card-text mb-1">
                  <b>Active Bookings:</b> <%= stats.activeBookings %>
                </p>
                <p class="card-text mb-3">
                  <b>Paid Bookings:</b> <%= stats.paidBookings %>
                </p>

                <div class="d-flex flex-wrap gap-2">
                  <a href="/listings/<%= listing._id %>" class="btn btn-outline-dark btn-sm">View</a>
                  <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-primary btn-sm">Edit</a>
                  <form method="POST" action="/admin/listings/<%= listing._id %>?_method=DELETE" onsubmit="return confirm('Delete this listing and its related bookings?');">
                    <button class="btn btn-outline-danger btn-sm">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
