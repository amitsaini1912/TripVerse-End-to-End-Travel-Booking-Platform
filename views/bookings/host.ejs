<% layout("./layouts/boilerplate.ejs") -%>

<div class="row mt-3">
  <div class="col-10 offset-1">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3>Host Booking Requests</h3>
      <a href="/bookings/host/dashboard" class="btn btn-outline-dark btn-sm">View Analytics</a>
    </div>

    <% if (hostBookings.length === 0) { %>
      <div class="alert alert-info mt-3">
        No booking requests found for your listings.
      </div>
    <% } else { %>
      <div class="row mt-3">
        <% for (let booking of hostBookings) { %>
          <div class="col-lg-6 mb-3">
            <div class="card h-100">
              <img
                src="<%= (booking.listing && booking.listing.image && booking.listing.image.url) ? booking.listing.image.url : 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1200&auto=format&fit=crop' %>"
                class="card-img-top"
                alt="host_booking_listing_image"
                style="height: 14rem;"
              >
              <div class="card-body">
                <h5 class="card-title">
                  <%= booking.listing ? booking.listing.title : "Listing unavailable" %>
                </h5>
                <p class="card-text mb-1"><b>Guest:</b> <%= booking.guest ? booking.guest.username : "N/A" %></p>
                <p class="card-text mb-1"><b>Email:</b> <%= booking.guest ? booking.guest.email : "N/A" %></p>
                <p class="card-text mb-1"><b>Check-in:</b> <%= booking.checkIn.toDateString() %></p>
                <p class="card-text mb-1"><b>Check-out:</b> <%= booking.checkOut.toDateString() %></p>
                <p class="card-text mb-1"><b>Guests:</b> <%= booking.guests %></p>
                <p class="card-text mb-1"><b>Total:</b> INR <%= booking.totalAmount.toLocaleString("en-IN") %></p>

                <p class="card-text mb-2">
                  <b>Status:</b>
                  <span class="badge text-bg-<%= booking.status === 'confirmed' ? 'success' : (booking.status === 'pending' ? 'warning' : 'secondary') %>">
                    <%= booking.status %>
                  </span>
                </p>

                <% if (booking.status === "pending") { %>
                  <div class="d-flex gap-2">
                    <form method="POST" action="/bookings/<%= booking._id %>/status?_method=PATCH">
                      <%- include("../includes/csrf.ejs") %>
                      <input type="hidden" name="status" value="confirmed">
                      <button class="btn btn-success btn-sm">Approve</button>
                    </form>
                    <form method="POST" action="/bookings/<%= booking._id %>/status?_method=PATCH">
                      <%- include("../includes/csrf.ejs") %>
                      <input type="hidden" name="status" value="rejected">
                      <button class="btn btn-outline-danger btn-sm">Reject</button>
                    </form>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
