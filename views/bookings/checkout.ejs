<% layout("./layouts/boilerplate.ejs") -%>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3>Checkout</h3>
      <a href="/bookings/me" class="btn btn-outline-dark btn-sm">Back to My Bookings</a>
    </div>

    <div class="card">
      <img
        src="<%= (booking.listing && booking.listing.image && booking.listing.image.url) ? booking.listing.image.url : 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1200&auto=format&fit=crop' %>"
        class="card-img-top"
        alt="checkout_listing_image"
        style="height: 18rem;"
      >
      <div class="card-body">
        <h5 class="card-title"><%= booking.listing ? booking.listing.title : "Listing unavailable" %></h5>
        <p class="card-text mb-1"><b>Check-in:</b> <%= booking.checkIn.toDateString() %></p>
        <p class="card-text mb-1"><b>Check-out:</b> <%= booking.checkOut.toDateString() %></p>
        <p class="card-text mb-1"><b>Guests:</b> <%= booking.guests %></p>
        <p class="card-text mb-1"><b>Total:</b> INR <%= booking.totalAmount.toLocaleString("en-IN") %></p>
        <p class="card-text mb-3"><b>Payment Status:</b> <%= booking.paymentStatus %></p>
        <% if (booking.lastPaymentErrorMessage) { %>
          <div class="alert alert-danger">
            <b>Last payment issue:</b> <%= booking.lastPaymentErrorMessage %>
          </div>
        <% } %>

        <% if (!stripePublishableKey) { %>
          <div class="alert alert-warning mb-0">
            Stripe publishable key is missing. Add `STRIPE_PUBLISHABLE_KEY` and `STRIPE_SECRET_KEY` to enable payments.
          </div>
        <% } else { %>
          <% if (booking.paymentStatus === "failed") { %>
            <div class="alert alert-warning">
              Your previous payment did not complete. You can try again below.
            </div>
          <% } %>
          <div id="checkoutLoader" class="alert alert-info">Preparing secure checkout...</div>
          <form id="payment-form" style="display:none;">
            <div id="payment-element" class="mb-3"></div>
            <button id="submit-payment-btn" class="btn btn-dark" type="submit">Pay Now</button>
          </form>
          <div id="paymentFeedback" class="mt-3"></div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<% if (stripePublishableKey) { %>
  <script src="https://js.stripe.com/v3/"></script>
  <script>
    const checkoutLoader = document.getElementById("checkoutLoader");
    const paymentForm = document.getElementById("payment-form");
    const paymentElementContainer = document.getElementById("payment-element");
    const submitPaymentBtn = document.getElementById("submit-payment-btn");
    const paymentFeedback = document.getElementById("paymentFeedback");
    const bookingId = "<%= booking._id %>";
    const returnUrl = `${window.location.origin}/bookings/${bookingId}/pay/complete`;
    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || "";

    async function syncPaymentCompletion(paymentIntentId) {
      const query = new URLSearchParams({ payment_intent: paymentIntentId });
      window.location.href = `/bookings/${bookingId}/pay/complete?${query.toString()}`;
    }

    async function initializeCheckout() {
      if (!paymentForm || !paymentElementContainer || !paymentFeedback) return;

      try {
        const response = await fetch(`/bookings/${bookingId}/payment-intent`, {
          method: "POST",
          headers: {
            "Accept": "application/json",
            ...(csrfToken ? { "CSRF-Token": csrfToken } : {}),
          },
        });
        const data = await response.json();

        if (!response.ok) {
          if (checkoutLoader) checkoutLoader.style.display = "none";
          paymentFeedback.innerHTML = `<div class="alert alert-danger mb-0">${data.message || "Unable to prepare payment."}</div>`;
          return;
        }

        const stripe = Stripe(data.publishableKey);
        const elements = stripe.elements({
          clientSecret: data.clientSecret,
          appearance: {
            theme: "stripe",
          },
        });
        const paymentElement = elements.create("payment");
        paymentElement.mount("#payment-element");

        if (checkoutLoader) checkoutLoader.style.display = "none";
        paymentForm.style.display = "block";

        paymentForm.addEventListener("submit", async (event) => {
          event.preventDefault();
          paymentFeedback.innerHTML = "";
          submitPaymentBtn.disabled = true;
          submitPaymentBtn.innerText = "Processing...";

          const { error } = await stripe.confirmPayment({
            elements,
            confirmParams: {
              return_url: returnUrl,
            },
            redirect: "if_required",
          });

          if (error) {
            paymentFeedback.innerHTML = `<div class="alert alert-danger mb-0">${error.message || "Payment could not be completed."}</div>`;
            submitPaymentBtn.disabled = false;
            submitPaymentBtn.innerText = "Pay Now";
            return;
          }

          const { paymentIntent } = await stripe.retrievePaymentIntent(data.clientSecret);
          if (!paymentIntent) {
            paymentFeedback.innerHTML = '<div class="alert alert-danger mb-0">Unable to verify payment status.</div>';
            submitPaymentBtn.disabled = false;
            submitPaymentBtn.innerText = "Pay Now";
            return;
          }

          await syncPaymentCompletion(paymentIntent.id);
        });
      } catch (err) {
        if (checkoutLoader) checkoutLoader.style.display = "none";
        paymentFeedback.innerHTML = '<div class="alert alert-danger mb-0">Unable to reach the payment service right now.</div>';
      }
    }

    initializeCheckout();
  </script>
<% } %>
