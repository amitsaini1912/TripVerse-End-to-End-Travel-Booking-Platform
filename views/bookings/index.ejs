

<div class="row mt-3">
  <div class="col-10 offset-1">
    <h3>My Bookings</h3>

    <% if (myBookings.length === 0) { %>
      <div class="alert alert-info mt-3">
        You do not have any bookings yet.
      </div>
      <a href="/listings" class="btn btn-dark">Explore Listings</a>
    <% } else { %>
      <div class="row mt-3">
        <% for (let booking of myBookings) { %>
          <div class="col-lg-6 mb-3">
            <div class="card h-100">
              <img
                src="<%= (booking.listing && booking.listing.image && booking.listing.image.url) ? booking.listing.image.url : 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=1200&auto=format&fit=crop' %>"
                class="card-img-top"
                alt="booking_listing_image"
                style="height: 14rem;"
              >
              <div class="card-body">
                <h5 class="card-title">
                  <%= booking.listing ? booking.listing.title : "Listing unavailable" %>
                </h5>
                <p class="card-text mb-1">
                  <b>Check-in:</b> <%= booking.checkIn.toDateString() %>
                </p>
                <p class="card-text mb-1">
                  <b>Check-out:</b> <%= booking.checkOut.toDateString() %>
                </p>
                <p class="card-text mb-1">
                  <b>Guests:</b> <%= booking.guests %>
                </p>
                <p class="card-text mb-1">
                  <b>Total:</b> INR <%= booking.totalAmount.toLocaleString("en-IN") %>
                </p>
                <p class="card-text mb-2">
                  <b>Status:</b>
                  <span class="badge text-bg-<%= booking.status === 'confirmed' ? 'success' : (booking.status === 'pending' ? 'warning' : 'secondary') %>">
                    <%= booking.status %>
                  </span>
                </p>

                <div class="d-flex gap-2">
                  <% if (booking.listing) { %>
                    <a href="/listings/<%= booking.listing._id %>" class="btn btn-outline-dark btn-sm">View Listing</a>
                  <% } %>

                  <% if (booking.status === "pending" || booking.status === "confirmed") { %>
                    <form action="/bookings/<%= booking._id %>/cancel?_method=PATCH" method="POST">
                      <button class="btn btn-danger btn-sm">Cancel Booking</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
